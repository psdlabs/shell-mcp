{
  "name": "shell-mcp-monorepo",
  "private": true,
  "type": "module",
  "description": "MCP server giving any AI client persistent shell access via named sessions",
  "license": "MIT",
  "author": {
    "name": "psdlabs",
    "email": "prasanthsd44@gmail.com",
    "url": "https://www.linkedin.com/in/prasanthsd"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/psdlabs/shell-mcp.git"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @shell-mcp/core run build",
    "build:lite": "pnpm --filter @shell-mcp/mcp-lite run build",
    "build:daemon": "pnpm --filter @shell-mcp/daemon run build",
    "build:full": "pnpm --filter @shell-mcp/mcp-full run build",
    "build:cli": "pnpm --filter shell-mcp run build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["node-pty"]
  }
}
